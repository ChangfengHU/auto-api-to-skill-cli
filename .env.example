# 复制此文件为 ~/.agent-brain-plugins.env 并填入真实值
# cp .env.example ~/.agent-brain-plugins.env

# ── GitHub ────────────────────────────────────────────────────────────────────
# 用于 --create-remote 时推送仓库（Personal Access Token，需要 repo 权限）
CHANGFENG_TOKEN=your_github_personal_access_token

# ── Cloudflare（Case 1: cloudflare_worker 部署用）────────────────────────────
# 登录邮箱
CF_EMAIL_SKILL=your_cloudflare_email@example.com

# Global API Key（在 CF 控制台 → My Profile → API Tokens → Global API Key）
CF_API_KEY_SKILL=your_cloudflare_global_api_key

# Account ID（CF 控制台右侧边栏，或 Workers 概览页）
CF_ACCOUNT_ID_SKILL=your_cloudflare_account_id

# Workers 子域名（CF 控制台 → Workers & Pages → 你的 workers.dev 子域名）
# Worker URL 格式：https://auto-api-{slug}.{CF_WORKERS_SUBDOMAIN}.workers.dev
CF_WORKERS_SUBDOMAIN=your_workers_subdomain
